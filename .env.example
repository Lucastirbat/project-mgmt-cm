# Copy this to .dev.vars for local Wrangler development.
# NEVER commit .dev.vars — it's in .gitignore.
#
# In production, set these in the Cloudflare Pages dashboard:
#   Settings → Environment Variables

# The shared password users enter on the login screen
SITE_PASSWORD=change-me-to-a-strong-password

# A random secret used to sign session tokens (min 32 chars)
# Generate one with: openssl rand -hex 32
SESSION_SECRET=generate-a-random-secret-here
